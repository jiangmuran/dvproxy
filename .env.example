# DVProxy Configuration
# Copy this file to .env and modify as needed

# Server Settings
DVPROXY_HOST=0.0.0.0
DVPROXY_PORT=8080
DVPROXY_DEBUG=false

# Database
# SQLite (default)
DVPROXY_DATABASE_URL=sqlite+aiosqlite:///./dvproxy.db
# PostgreSQL (optional)
# DVPROXY_DATABASE_URL=postgresql+asyncpg://user:pass@localhost/dvproxy

# Upstream DeepVLab API
DVPROXY_UPSTREAM_URL=https://api-code.deepvlab.ai
DVPROXY_UPSTREAM_TOKEN=your_token_here

# Admin Credentials
DVPROXY_ADMIN_USERNAME=jmr
# TOTP Secret (base32 encoded) - Use a new one in production!
DVPROXY_TOTP_SECRET=JBSWY3DPEHPK3PXP

# JWT Settings (optional - a random secret is generated if not set)
# DVPROXY_JWT_SECRET=your_very_secret_key_here
DVPROXY_JWT_EXPIRE_MINUTES=1440

# Client Version (mimics DeepVCode)
DVPROXY_CLIENT_VERSION=1.0.93
